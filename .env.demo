# ════════════════════════════════════════════════════════════════════
#  AutoPay AI — DEMO CONFIG  (do NOT use in production)
#  Keys below are pre-generated for local development / demos only.
#  Run `make keygen` to rotate them before any real deployment.
# ════════════════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=sYhVplVTlOjgDE8qrdkCqAbgKiSMrsQ6fbV80KusiZU
APP_PORT=8000

# ─── Database ────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=David*2020*
POSTGRES_DB=autopay
POSTGRES_PORT=5432

# Connect to a local Postgres instance (default).
# If using Docker (`make up`), this is wired automatically.
DATABASE_URL=postgresql://postgres:David*2020*@localhost:5432/autopay

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ─── Paystack ────────────────────────────────────────────────────────
# Replace with keys from https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_replace_with_real_test_key
PAYSTACK_PUBLIC_KEY=pk_test_replace_with_real_test_key
PAYSTACK_BASE_URL=https://api.paystack.co

# ─── Telegram ────────────────────────────────────────────────────────
# Get a token from @BotFather on Telegram. Leave blank to disable the bot.
TELEGRAM_BOT_TOKEN=
# Bot username WITHOUT the leading @  (e.g. AutoPayDemoBot)
TELEGRAM_BOT_USERNAME=
# Leave blank to use polling mode in dev. Set to a public HTTPS URL in prod.
WEBHOOK_URL=

# ─── LLM ─────────────────────────────────────────────────────────────
# At least one key enables the LangGraph decision agent.
# Without these the bill loader falls back to regex extraction.
GROQ_API_KEY=
GOOGLE_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false

# ─── Fees ────────────────────────────────────────────────────────────
PAYOUT_FEE_NGN=50.00

# ─── Security keys ───────────────────────────────────────────────────
# BVN_ENCRYPTION_KEY — Fernet (AES-128-CBC + HMAC-SHA256).
#   Encrypts BVN digits stored in kyc_records.bvn_ciphertext.
#   WARNING: changing this key makes all stored BVNs unreadable.
#   Regenerate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BVN_ENCRYPTION_KEY=QTigPLV_KN66ej41FBEkV_zcvYdf4uceEG5LSMfJFYI=

# JWT_SECRET_KEY — HMAC-SHA256 secret that signs all access + refresh tokens.
#   Changing this immediately invalidates all active sessions.
#   Regenerate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CDSLDZm65RomHFDpxssGkjyp4Sgxm_PY5uJQfJDYWGSRy2B-W4BCfieyiHna_I_NrtPMT1T6ra3mSkxsMLxPkw
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ─── DVA provisioning ────────────────────────────────────────────────
# Keep false until your Paystack business is approved for Dedicated NUBANs.
# When true, signup calls Paystack to create a virtual account inline.
AUTO_PROVISION_DVA_ON_SIGNUP=false
