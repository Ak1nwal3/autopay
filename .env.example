# ─── App ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-32-char-random-string-use-secrets-token-urlsafe
APP_PORT=8000

# ─── Database ───────────────────────────────────────────────────────
# These three are used by docker-compose.yml to provision the Postgres container.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=David*2020*
POSTGRES_DB=nomba_gateway
POSTGRES_PORT=5432

# DATABASE_URL is constructed by docker-compose from the values above.
# For local runs (uvicorn outside Docker), uncomment one of these:
#
#   Option A — connect to an existing local Postgres on this machine
#              (the default in app/core/config.py already targets this):
DATABASE_URL=postgresql://postgres:David*2020*@localhost:5432/nomba_gateway
#
#   Option B — connect to the Docker postgres service (run `make up` first):
#   DATABASE_URL=postgresql://autopay:autopay@localhost:5432/nomba_gateway
#
#   Option C — use a different superuser/password you have on this machine:
#   DATABASE_URL=postgresql://YOUR_USER:YOUR_PASSWORD@localhost:5432/nomba_gateway

DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_ECHO=false

# ─── Nomba (REQUIRED) ───────────────────────────────────────────────
# OAuth2 client_credentials issued by Nomba. Get these from
# https://sandbox.nomba.com (or your live account dashboard).
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
# Parent business account UUID — Nomba sends this on every call.
NOMBA_ACCOUNT_ID=
# HMAC-SHA256 secret used to verify the `nomba-signature` header on
# incoming webhooks. Must match the value configured in the Nomba
# dashboard for this webhook URL.
NOMBA_WEBHOOK_SECRET=

# ─── Telegram ───────────────────────────────────────────────────────
# Get from @BotFather. Leaving this empty disables the bot.
TELEGRAM_BOT_TOKEN=
# Bot username WITHOUT the leading @. Used in deep-link URLs
# (https://t.me/<username>?start=<code>). Optional.
TELEGRAM_BOT_USERNAME=
# Production: Telegram pushes to this URL. Empty = polling mode (dev only).
# Should end in /telegram/webhook (the route mounted by app.main).
WEBHOOK_URL=https://your-domain.example/telegram/webhook

# ─── CORS ────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call the API from a
# browser. Default covers the common local-dev setups.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8000,http://127.0.0.1:8000

# ─── LLM ────────────────────────────────────────────────────────────
GROQ_API_KEY=
GOOGLE_API_KEY=
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false

# ─── Fees ───────────────────────────────────────────────────────────
PAYOUT_FEE_NGN=50.00

# ─── Security ───────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BVN_ENCRYPTION_KEY=
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=7

# ─── DVA auto-provision on signup ───────────────────────────────────
# If true, signup synchronously calls Nomba to create a DVA. If false
# (default), the DVA is created lazily on first /wallet/provision call.
AUTO_PROVISION_DVA_ON_SIGNUP=false
